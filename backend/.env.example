# Supabase / Postgres
SUPABASE_URL=https://your-project.supabase.co
# For development you can use a publishable key, BUT for server operations use the service role key:
SUPABASE_KEY=sb_publishable_xxx
# Recommended: set the service role key as SUPABASE_SERVICE_ROLE for server to bypass RLS
SUPABASE_SERVICE_ROLE=service_role_xxx

# Server
PORT=5000

# Test admin credentials (optional)
TEST_ADMIN=superadmin
TEST_PASS=changeme
